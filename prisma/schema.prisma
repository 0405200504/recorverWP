generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id                String             @id @default(dbgenerated("(gen_random_uuid())::text"))
  name              String
  timezone          String             @default("America/Sao_Paulo")
  currency          String             @default("BRL")
  webhook_secret    String             @default(dbgenerated("(gen_random_uuid())::text"))
  createdAt         DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime           @default(now()) @updatedAt @db.Timestamptz(6)
  campaigns         Campaign[]
  leads             Lead[]
  users             Membership[]
  messages          Message[]
  orders            Order[]
  runs              RecoveryRun[]
  webhookConfigs    WebhookConfig[]
  whatsappNumbers   WhatsAppNumber[]
  whatsappTemplates WhatsAppTemplate[]
}

model User {
  id           String       @id @default(dbgenerated("(gen_random_uuid())::text"))
  name         String?
  email        String       @unique
  passwordHash String
  createdAt    DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime     @default(now()) @updatedAt @db.Timestamptz(6)
  memberships  Membership[]
}

model Membership {
  id             String       @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId         String
  organizationId String
  role           String
  createdAt      DateTime     @default(now()) @db.Timestamptz(6)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, organizationId])
}

model WhatsAppNumber {
  id             String       @id @default(dbgenerated("(gen_random_uuid())::text"))
  organizationId String
  phoneNumberId  String
  wabaId         String
  accessToken    String
  displayName    String?
  status         String       @default("active")
  createdAt      DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime     @default(now()) @updatedAt @db.Timestamptz(6)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model WebhookConfig {
  id             String       @id @default(dbgenerated("(gen_random_uuid())::text"))
  organizationId String
  provider       String
  name           String
  clientId       String?
  clientSecret   String?
  webhookToken   String?
  createdAt      DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime     @default(now()) @updatedAt @db.Timestamptz(6)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model Lead {
  id              String       @id @default(dbgenerated("(gen_random_uuid())::text"))
  organizationId  String
  name            String?
  phoneE164       String
  email           String?
  consentWhatsapp Boolean      @default(false)
  consentSource   String?
  consentAt       DateTime?    @db.Timestamptz(6)
  tags            String?
  lastSeenAt      DateTime     @default(now()) @db.Timestamptz(6)
  createdAt       DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime     @default(now()) @updatedAt @db.Timestamptz(6)
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  messages        Message[]
  orders          Order[]

  @@unique([organizationId, phoneE164])
}

model Order {
  id              String        @id @default(dbgenerated("(gen_random_uuid())::text"))
  organizationId  String
  leadId          String
  externalOrderId String
  provider        String
  status          String
  paymentMethod   String?
  amount          Float
  currency        String        @default("BRL")
  checkoutUrl     String?
  pixCopyPaste    String?
  createdAt       DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime      @default(now()) @updatedAt @db.Timestamptz(6)
  lead            Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  events          OrderEvent[]
  runs            RecoveryRun[]

  @@unique([organizationId, provider, externalOrderId])
}

model OrderEvent {
  id                String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  orderId           String
  eventType         String
  rawPayload        String
  normalizedPayload String
  createdAt         DateTime @default(now()) @db.Timestamptz(6)
  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model Campaign {
  id                         String        @id @default(dbgenerated("(gen_random_uuid())::text"))
  organizationId             String
  name                       String
  active                     Boolean       @default(true)
  triggerEventTypes          String
  matchingRules              String?
  stopOnEventTypes           String
  maxAttemptsPerLeadPerOrder Int           @default(3)
  createdAt                  DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt                  DateTime      @default(now()) @updatedAt @db.Timestamptz(6)
  steps                      CadenceStep[]
  organization               Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  runs                       RecoveryRun[]
}

model CadenceStep {
  id           String         @id @default(dbgenerated("(gen_random_uuid())::text"))
  campaignId   String
  stepOrder    Int
  delayMinutes Int?
  delaySeconds Int            @default(0)
  messageType  String
  templateName String?
  contentText  String?
  mediaUrl     String?
  buttons      String?
  sendOnlyIf   String         @default("qualquer")
  createdAt    DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime       @default(now()) @updatedAt @db.Timestamptz(6)
  campaign     Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  dispatches   StepDispatch[]
}

model RecoveryRun {
  id             String         @id @default(dbgenerated("(gen_random_uuid())::text"))
  organizationId String
  orderId        String
  campaignId     String
  status         String         @default("scheduled")
  createdAt      DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime       @default(now()) @updatedAt @db.Timestamptz(6)
  campaign       Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  order          Order          @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  dispatches     StepDispatch[]

  @@unique([orderId, campaignId])
}

model StepDispatch {
  id           String      @id @default(dbgenerated("(gen_random_uuid())::text"))
  runId        String
  stepId       String
  scheduledFor DateTime    @db.Timestamptz(6)
  status       String      @default("pending")
  attempts     Int         @default(0)
  lastError    String?
  sentAt       DateTime?   @db.Timestamptz(6)
  createdAt    DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime    @default(now()) @updatedAt @db.Timestamptz(6)
  run          RecoveryRun @relation(fields: [runId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  step         CadenceStep @relation(fields: [stepId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model Message {
  id             String       @id @default(dbgenerated("(gen_random_uuid())::text"))
  organizationId String
  leadId         String
  orderId        String?
  direction      String
  channel        String       @default("whatsapp")
  waMessageId    String?      @unique
  payload        String
  status         String       @default("sent")
  createdAt      DateTime     @default(now()) @db.Timestamptz(6)
  lead           Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model WhatsAppTemplate {
  id              String       @id @default(dbgenerated("(gen_random_uuid())::text"))
  organizationId  String
  name            String
  language        String       @default("pt_BR")
  category        String       @default("MARKETING")
  status          String       @default("APPROVED")
  sampleVariables String?
  createdAt       DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime     @default(now()) @updatedAt @db.Timestamptz(6)
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([organizationId, name, language])
}
